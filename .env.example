# Postgres
POSTGRES_USER=leadgen
POSTGRES_PASSWORD=leadgen_password
POSTGRES_DB=leadgen
DATABASE_URL=postgresql://leadgen:leadgen_password@postgres:5432/leadgen
IDENTITY_DATABASE_URL=postgresql+psycopg://leadgen:leadgen_password@postgres:5432/leadgen
LEADGEN_DATABASE_URL=postgresql://leadgen:leadgen_password@postgres:5432/leadgen
LEADSTORE_DATABASE_URL=postgresql://leadgen:leadgen_password@postgres:5432/leadgen

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_ALGORITHM=HS256
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_EXPIRES_MINUTES=30
JWT_REFRESH_EXPIRES_DAYS=7
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=

# AI providers
OPENAI_API_KEY=replace-with-openai-key
OPENAI_PROJECT_ID=replace-with-openai-project-id
OLLAMA_BASE_URL=http://ollama:11434

# Data providers
FIRECRAWL_API_KEY=replace-with-firecrawl-key

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=replace-with-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=replace-with-r2-bucket
CLOUDFLARE_R2_PUBLIC_URL=replace-with-r2-public-url
